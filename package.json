{
  "name": "ui-motion-grabber",
  "version": "0.1.0",
  "private": true,
  "description": "UI Motion Grabber - a 100% local, zero-dependency Chromium MV3 extension that reverse-engineers live UI micro-interactions. This package configures the React + Vite + Tailwind Popup_UI build and the Vitest + fast-check test runner.",
  "license": "MIT",
  "type": "module",
  "scripts": {
    "build": "vite build",
    "build:ext": "node scripts/build-extension.mjs",
    "dev": "vite",
    "test": "vitest --run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  },
  "devDependencies": {
    "@testing-library/jest-dom": "^6.6.3",
    "@testing-library/react": "^16.1.0",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@vitejs/plugin-react": "^4.3.4",
    "autoprefixer": "^10.4.20",
    "fast-check": "^3.23.2",
    "jsdom": "^25.0.1",
    "postcss": "^8.4.49",
    "tailwindcss": "^3.4.17",
    "typescript": "^5.7.2",
    "vite": "^5.4.11",
    "vitest": "^2.1.8"
  }
}
