{
  "enabled": true,
  "name": "Auto-commit to GitHub after each prompt",
  "description": "After the agent finishes responding to a prompt, stage all changes, commit, and push to the origin remote on the current branch. Skips cleanly when there is nothing to commit.",
  "version": "1",
  "when": {
    "type": "agentStop"
  },
  "then": {
    "type": "runCommand",
    "command": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/auto-commit.ps1",
    "timeout": 180
  }
}